# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored — never commit real keys.

# URL of the deployed Cloudflare Worker (see workers/README.md).
# Leave unset to keep the admin form in "show JSON to copy/paste manually" fallback mode.
VITE_WORKER_URL=

# Cloudflare Turnstile site key — public, safe to expose in the bundle.
# For local dev without a real Turnstile widget, use the always-pass test key:
#   1x00000000000000000000AA
# Leave unset to hide the Suggest-a-Bag form on /encyclopedia.
VITE_TURNSTILE_SITE_KEY=
